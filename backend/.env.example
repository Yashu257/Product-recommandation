# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/cadence_db?schema=public"

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── File Uploads ─────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# ─── Scheduler ────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_CRON=* * * * *

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
